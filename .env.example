# Copy to .env and fill in ONLY the providers you selected in config/settings.yaml.

# ── LLM (scripts + ideas) — fill in only the one matching llm.provider ──
# PAID:
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# FREE options:
#   ollama  = 100% local, needs NO key (just run `ollama serve`)
#   groq    = free tier, get a key at https://console.groq.com
GROQ_API_KEY=
#   openrouter = free models, get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
#   gemini  = Google free tier, get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Voiceover ──
# edge-tts (default) needs NO key. Only fill this for premium voices:
ELEVENLABS_API_KEY=

# ── Visuals ──
# PEXELS_API_KEY = free stock video (default). FAL_KEY / REPLICATE = AI images (optional).
PEXELS_API_KEY=
FAL_KEY=
REPLICATE_API_TOKEN=

# ── Publishing (pick one aggregator) ──
# AYRSHARE posts to YT/TikTok/IG/FB from one token. UPLOAD_POST is an alternative.
AYRSHARE_API_KEY=
UPLOAD_POST_API_KEY=
UPLOAD_POST_USER=
